<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.map.seatingmapgenerator.controller.ChartCreation"
            prefHeight="400.0" prefWidth="600.0">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <top>
        <VBox>
            <HBox spacing="20"
                  alignment="CENTER_LEFT">

                <Button fx:id="goBack"
                        text="Voltar"
                        styleClass="returnButton"
                        onAction="#goBack" />

                <Label text="Criador de mapas"
                       styleClass="title" />

                <Region HBox.hgrow="ALWAYS"/>

                <Label text="v1.0.0"
                       styleClass="version" />
            </HBox>

            <Separator/>

        </VBox>
    </top>

    <center>
        <VBox alignment="CENTER"
              spacing="15">

            <HBox alignment="CENTER"
                  spacing="15">

                <TreeTableView fx:id="studentTable"
                               maxHeight="370"
                               HBox.hgrow="ALWAYS"
                               styleClass="resultTable">

                    <columns>
                        <TreeTableColumn fx:id="selectedStudentColumn"
                                         prefWidth="60"
                                         resizable="false"/>

                        <TreeTableColumn fx:id="studentIdColumn"
                                         prefWidth="100"
                                         resizable="false"
                                         text="Matrícula"/>

                        <TreeTableColumn fx:id="nameColumn"
                                         prefWidth="370"
                                         resizable="false"
                                         text="Nome"/>

                    </columns>
                </TreeTableView>

                <TableView fx:id="classroomTable"
                           maxHeight="370"
                           HBox.hgrow="ALWAYS"
                           styleClass="resultTable">

                    <columns>
                        <TableColumn fx:id="selectedClassroomColumn"
                                     prefWidth="60"
                                     resizable="false"/>

                        <TableColumn fx:id="classroomIdColumn"
                                     prefWidth="150"
                                     resizable="false"
                                     text="Nome"/>


                        <TableColumn fx:id="capacityColumn"
                                     prefWidth="100"
                                     resizable="false"
                                     text="Capacidade"/>

                    </columns>
                </TableView>
            </HBox>

            <HBox alignment="CENTER"
                  spacing="15">

                <Label fx:id="errorLabel"
                       prefWidth="700.0"
                       prefHeight="70.0"
                       styleClass="errorMessage" />

                <Button fx:id="generateButton"
                        text="Gerar"
                        styleClass="generateButton"/>


            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER"
              styleClass="footer">

            <Label text="© 2026 Leonardo Omoto Sato"/>

        </HBox>
    </bottom>

</BorderPane>
