<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefWidth="500"
            prefHeight="400"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.map.seatingmapgenerator.controller.dialogs.RemoveStudentDialogController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <top>
        <VBox>
            <Label text="Remover aluno"
                   styleClass="title" />

            <Separator/>
        </VBox>
    </top>

   <center>

      <VBox BorderPane.alignment="CENTER"
            spacing="20">

            <Label text="Deseja remover o aluno"
                   styleClass="inputLabel"/>

            <Label fx:id="studentRemoved"
                   prefWidth="400.0"
                   prefHeight="70.0"
                   styleClass="errorMessage">

                   <padding>
                       <Insets top="20" right="20" bottom="20" left="20"/>
                   </padding>

            </Label>

            <Label text="Essa ação não pode ser desfeita"
                   styleClass="inputLabel"/>

            <HBox alignment="CENTER_RIGHT">

                <Button fx:id="cancelButton"
                        text="Cancelar"
                        styleClass="cancelButton"
                        onAction="#onCancel"/>

                <Button fx:id="deleteButton"
                        text="Deletar"
                        styleClass="deleteButton"
                        onAction="#onDelete"/>

            </HBox>

      </VBox>
   </center>
</BorderPane>

