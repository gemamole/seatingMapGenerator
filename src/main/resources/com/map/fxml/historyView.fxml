<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.map.seatingmapgenerator.controller.HistoryView"
            prefHeight="400.0" prefWidth="600.0">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <top>
        <VBox>
            <HBox spacing="20"
                  alignment="CENTER_LEFT">
                <Button fx:id="goBack"
                        text="Voltar"
                        styleClass="returnButton"
                        onAction="#goBack" />

                <Label text="Visualizar mapas"
                       styleClass="title" />

                <Region HBox.hgrow="ALWAYS"/>

                <Label text="v1.0.0"
                       styleClass="version" />
            </HBox>

            <Separator/>

            <TextField
                    fx:id="searchField"
                    promptText="Buscar por nome..."
                    styleClass="searchField"/>
        </VBox>
    </top>

    <center>
        <HBox alignment="CENTER"
              spacing="15">

            <TableView fx:id="chartTable"
                       maxHeight="400"
                       HBox.hgrow="ALWAYS"
                       styleClass="resultTable">

            </TableView>

        </HBox>
    </center>

    <bottom>
        <HBox alignment="CENTER"
              styleClass="footer">

            <Label text="© 2026 Leonardo Omoto Sato"/>

        </HBox>
    </bottom>

</BorderPane>
